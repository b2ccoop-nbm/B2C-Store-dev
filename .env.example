# Copy to apps/api/.dev.vars for local Worker dev (never commit .dev.vars)

POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/b2ccoop_store

# Public store URL (Astro build / Pages)
PUBLIC_STORE_URL=http://localhost:5175
PUBLIC_API_URL=http://localhost:8787

# Firebase (same project as WebApp — b2ccoop-87114)
# FIREBASE_PROJECT_ID=
# Set on Worker only — never PUBLIC_*

# Integrations (Phase 1+)
# WEBAPP_API_URL=http://localhost:3000
# WEBAPP_INTEGRATION_SECRET=
# ACCOUNTING_API_URL=http://localhost:3010
# ACCOUNTING_INTEGRATION_SECRET=

# Cloudflare Turnstile (Phase 1+)
# TURNSTILE_SECRET_KEY=

# Store API Worker — copy to apps/api/.dev.vars (see apps/api/.dev.vars.example)
# DEV_ADMIN_SECRET=password01

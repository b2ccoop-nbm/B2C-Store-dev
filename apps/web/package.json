{
  "name": "@b2ccoop/store-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 5175",
    "build": "astro check && astro build",
    "build:pages": "astro check && astro build --mode production",
    "deploy:pages": "npm run build:pages && wrangler pages deploy dist --project-name=b2ccoop-store",
    "preview": "astro preview --port 5175",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@b2ccoop/store-shared": "*",
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^12.5.0",
    "@nanostores/persistent": "^1.3.4",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.5.3",
    "nanostores": "^1.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.2"
  }
}

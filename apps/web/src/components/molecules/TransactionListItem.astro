---
import { formatPhp } from "@/lib/format";

interface Props {
  orderId: string;
  status: string;
  grossAmount: string;
  vendorCode: string;
  createdAt: string;
  patronageAmount?: string;
}

const { orderId, status, grossAmount, vendorCode, createdAt, patronageAmount } = Astro.props;
const date = new Date(createdAt).toLocaleDateString("en-PH", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const patronage = Number(patronageAmount) || 0;
const statusLabel = status.replace(/_/g, " ");
---

<article class="elevation-1 p-4">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <p class="text-price m-0 text-brand-600">{formatPhp(grossAmount)}</p>
      <p class="text-body-sm text-neutral-500 m-0 mt-1">{vendorCode} · {date}</p>
      {patronage > 0 ? (
        <p class="text-body-sm text-coop-600 m-0 mt-1">+{formatPhp(patronage)} patronage</p>
      ) : null}
    </div>
    <div class="text-right">
      <span class="inline-block rounded-full px-2 py-0.5 text-caption font-semibold bg-neutral-100 text-neutral-700">
        {statusLabel}
      </span>
      <p class="m-0 mt-2">
        <a href={`/order/${orderId}`} class="text-body-sm font-semibold text-brand-600 no-underline">
          Receipt →
        </a>
      </p>
    </div>
  </div>
</article>

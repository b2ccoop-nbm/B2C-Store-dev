---
import TrustBadge from "@/components/molecules/TrustBadge.astro";

interface Props {
  name: string;
  vendorCode: string;
  description?: string | null;
  listingCount: number;
}

const { name, vendorCode, description, listingCount } = Astro.props;
---

<header class="mb-8 rounded-xl bg-gradient-to-br from-merchant-50 to-brand-50 p-6 md:p-8">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div class="max-w-2xl">
      <p class="text-caption font-semibold uppercase tracking-wide text-merchant-600 m-0 mb-2">Seller storefront</p>
      <h1 class="text-display m-0">{name}</h1>
      {description ? (
        <p class="text-body text-neutral-600 mt-3 m-0">{description}</p>
      ) : (
        <p class="text-body text-neutral-500 mt-3 m-0">Shop products from this B2CCoop seller.</p>
      )}
    </div>
    <TrustBadge type="merchant-verified" />
  </div>
  <p class="text-body-sm text-neutral-500 mt-4 m-0">
    {listingCount} {listingCount === 1 ? "listing" : "listings"} · <span class="font-mono text-caption">{vendorCode}</span>
  </p>
</header>

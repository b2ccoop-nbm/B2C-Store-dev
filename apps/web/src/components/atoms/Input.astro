---
import { cn } from "@/lib/cn";

interface Props {
  id: string;
  name: string;
  label: string;
  type?: "text" | "email" | "tel" | "password" | "search" | "number" | "url";
  value?: string;
  placeholder?: string;
  hint?: string;
  error?: string;
  disabled?: boolean;
  required?: boolean;
  autocomplete?: string;
  inputMode?: "text" | "email" | "tel" | "numeric" | "decimal" | "search";
  class?: string;
}

const {
  id,
  name,
  label,
  type = "text",
  value,
  placeholder,
  hint,
  error,
  disabled = false,
  required = false,
  autocomplete,
  inputMode,
  class: className,
} = Astro.props;

const inputClass = cn(
  "w-full min-h-touch px-4 rounded-lg border bg-neutral-0 text-body text-neutral-900",
  error ? "border-danger-600" : "border-neutral-200 focus:border-brand-600",
  "focus:outline-none focus:ring-2 focus:ring-brand-600/30",
  disabled && "opacity-50 cursor-not-allowed",
  className,
);
---

<div class="flex flex-col gap-1.5">
  <label for={id} class="text-body-sm font-medium text-neutral-900">
    {label}
    {required && <span class="text-danger-600" aria-hidden="true"> *</span>}
  </label>
  <input
    id={id}
    name={name}
    type={type}
    value={value}
    placeholder={placeholder}
    disabled={disabled}
    required={required}
    autocomplete={autocomplete}
    inputmode={inputMode}
    class={inputClass}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={error ? `${id}-error` : hint ? `${id}-hint` : undefined}
  />
  {hint && !error && (
    <p id={`${id}-hint`} class="text-body-sm text-neutral-500">
      {hint}
    </p>
  )}
  {error && (
    <p id={`${id}-error`} class="text-body-sm text-danger-600" role="alert">
      {error}
    </p>
  )}
</div>

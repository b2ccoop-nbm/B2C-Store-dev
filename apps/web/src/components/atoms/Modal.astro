---
import { cn } from "@/lib/cn";

interface Props {
  id: string;
  title: string;
  class?: string;
}

const { id, title, class: className } = Astro.props;
---

<dialog
  id={id}
  class={cn(
    "backdrop:bg-neutral-900/50 m-auto max-w-lg w-[calc(100%-2rem)] rounded-xl border border-neutral-200 p-0 elevation-3 open:flex open:flex-col",
    className,
  )}
  aria-labelledby={`${id}-title`}
>
  <header class="flex items-center justify-between gap-4 border-b border-neutral-200 px-4 py-3">
    <h2 id={`${id}-title`} class="text-title-sm m-0">{title}</h2>
    <button
      type="button"
      class="touch-target inline-flex items-center justify-center rounded-lg text-neutral-500 hover:bg-neutral-50"
      data-modal-close={id}
      aria-label="Close dialog"
    >
      <span aria-hidden="true">×</span>
    </button>
  </header>
  <div class="p-4">
    <slot />
  </div>
</dialog>

<script>
  function bindModals() {
    document.querySelectorAll<HTMLDialogElement>("dialog[id]").forEach((dialog) => {
      const id = dialog.id;
      document.querySelectorAll(`[data-modal-open="${id}"]`).forEach((btn) => {
        btn.addEventListener("click", () => dialog.showModal());
      });
      document.querySelectorAll(`[data-modal-close="${id}"]`).forEach((btn) => {
        btn.addEventListener("click", () => dialog.close());
      });
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
      });
    });
  }
  bindModals();
  document.addEventListener("astro:page-load", bindModals);
</script>

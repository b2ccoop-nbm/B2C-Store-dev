---
import { cn } from "@/lib/cn";

interface Props {
  id: string;
  name: string;
  label: string;
  value?: string;
  placeholder?: string;
  hint?: string;
  error?: string;
  rows?: number;
  disabled?: boolean;
  required?: boolean;
  class?: string;
}

const {
  id,
  name,
  label,
  value,
  placeholder,
  hint,
  error,
  rows = 4,
  disabled = false,
  required = false,
  class: className,
} = Astro.props;

const areaClass = cn(
  "w-full px-4 py-3 rounded-lg border bg-neutral-0 text-body text-neutral-900 resize-y min-h-[6rem]",
  error ? "border-danger-600" : "border-neutral-200 focus:border-brand-600",
  "focus:outline-none focus:ring-2 focus:ring-brand-600/30",
  disabled && "opacity-50 cursor-not-allowed",
  className,
);
---

<div class="flex flex-col gap-1.5">
  <label for={id} class="text-body-sm font-medium text-neutral-900">
    {label}
    {required && <span class="text-danger-600" aria-hidden="true"> *</span>}
  </label>
  <textarea
    id={id}
    name={name}
    rows={rows}
    placeholder={placeholder}
    disabled={disabled}
    required={required}
    class={areaClass}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={error ? `${id}-error` : hint ? `${id}-hint` : undefined}>{value}</textarea
  >
  {hint && !error && (
    <p id={`${id}-hint`} class="text-body-sm text-neutral-500">
      {hint}
    </p>
  )}
  {error && (
    <p id={`${id}-error`} class="text-body-sm text-danger-600" role="alert">
      {error}
    </p>
  )}
</div>

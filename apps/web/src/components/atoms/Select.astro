---
import { cn } from "@/lib/cn";

interface Option {
  value: string;
  label: string;
}

interface Props {
  id: string;
  name: string;
  label: string;
  options: Option[];
  value?: string;
  hint?: string;
  error?: string;
  disabled?: boolean;
  required?: boolean;
  class?: string;
}

const {
  id,
  name,
  label,
  options,
  value,
  hint,
  error,
  disabled = false,
  required = false,
  class: className,
} = Astro.props;

const selectClass = cn(
  "w-full min-h-touch px-4 rounded-lg border bg-neutral-0 text-body text-neutral-900",
  error ? "border-danger-600" : "border-neutral-200 focus:border-brand-600",
  "focus:outline-none focus:ring-2 focus:ring-brand-600/30",
  disabled && "opacity-50 cursor-not-allowed",
  className,
);
---

<div class="flex flex-col gap-1.5">
  <label for={id} class="text-body-sm font-medium text-neutral-900">
    {label}
    {required && <span class="text-danger-600" aria-hidden="true"> *</span>}
  </label>
  <select
    id={id}
    name={name}
    disabled={disabled}
    required={required}
    class={selectClass}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={error ? `${id}-error` : hint ? `${id}-hint` : undefined}
  >
    {options.map((opt) => (
      <option value={opt.value} selected={value === opt.value}>
        {opt.label}
      </option>
    ))}
  </select>
  {hint && !error && (
    <p id={`${id}-hint`} class="text-body-sm text-neutral-500">
      {hint}
    </p>
  )}
  {error && (
    <p id={`${id}-error`} class="text-body-sm text-danger-600" role="alert">
      {error}
    </p>
  )}
</div>

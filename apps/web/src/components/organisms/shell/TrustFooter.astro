---
import { TRUST_COPY } from "@/lib/constants";

const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 bg-neutral-0 px-4 py-8 md:px-6 text-body-sm text-neutral-500">
  <div class="mx-auto max-w-7xl grid gap-6 sm:grid-cols-3 text-center sm:text-left">
    <div>
      <p class="m-0 font-semibold text-neutral-900">{TRUST_COPY.coopName}</p>
      <p class="mt-1 m-0 text-caption">{TRUST_COPY.registration}</p>
    </div>
    <div>
      <p class="m-0 font-medium text-neutral-900">Pickup</p>
      <p class="mt-1 m-0">{TRUST_COPY.pickupLocation}</p>
    </div>
    <div>
      <p class="m-0 font-medium text-neutral-900">Need help?</p>
      <p class="mt-1 m-0">
        <a href={`tel:${TRUST_COPY.helpPhone.replace(/\s/g, "")}`} class="text-brand-600 font-semibold no-underline">
          {TRUST_COPY.helpPhone}
        </a>
      </p>
    </div>
  </div>
  <p class="mt-6 m-0 text-center text-caption">Member-owned marketplace · Trust by default · © {year} B2CCoop</p>
</footer>

---
import Button from "@/components/atoms/Button.astro";
import Price from "@/components/molecules/Price.astro";
import { addToCartLabel, cartPayloadFromItem } from "@/lib/offering";
import type { CatalogItemPublic } from "@b2ccoop/store-shared";

interface Props {
  offering: CatalogItemPublic;
}

const { offering } = Astro.props;
const cartPayload = cartPayloadFromItem(offering);
const addLabel = addToCartLabel(offering.name);
---

<div
  class="fixed bottom-0 inset-x-0 z-40 border-t border-neutral-200 bg-neutral-0/95 backdrop-blur px-4 py-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] elevation-2 md:hidden"
>
  <div class="mx-auto flex max-w-lg items-center gap-3">
    <Price amount={offering.unitPrice} class="shrink-0" />
    <Button
      type="button"
      variant="primary"
      fullWidth
      class="b2c-add-to-cart"
      data-cart-item={cartPayload}
      ariaLabel={addLabel}
    >
      Add to cart
    </Button>
  </div>
</div>

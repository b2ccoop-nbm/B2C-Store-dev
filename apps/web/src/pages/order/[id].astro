---
import MarketplaceLayout from "@/layouts/MarketplaceLayout.astro";
import Button from "@/components/atoms/Button.astro";
import Badge from "@/components/atoms/Badge.astro";
import Card from "@/components/atoms/Card.astro";
import type { OrderDetail } from "@b2ccoop/store-shared";
import { API_BASE } from "@/lib/api";
import { formatPhp } from "@/lib/format";
import { orderStatusLabel } from "@/lib/order-status";

const { id } = Astro.params;
let order: OrderDetail | null = null;
let error = "";

if (!id) {
  error = "Missing order id";
} else {
  try {
    const res = await fetch(`${API_BASE}/orders/${id}`);
    if (!res.ok) {
      error = "Order not found";
    } else {
      order = (await res.json()) as OrderDetail;
    }
  } catch {
    error = "Could not load order — is the API running?";
  }
}

const statusVariant =
  order?.status === "POSTED_TO_LEDGER"
    ? "success"
    : order?.status === "FAILED"
      ? "danger"
      : order?.status === "PENDING_PICKUP"
        ? "warning"
        : "neutral";

const showStaffConfirm =
  order?.status === "PENDING_PICKUP" || order?.status === "FAILED";
---

<MarketplaceLayout title={order ? `Order ${order.orderId.slice(0, 8)}…` : "Order"} hideBottomNav>
  {
    error ? (
      <Card>
        <p class="text-danger-600 m-0">{error}</p>
        <Button href="/activity" variant="ghost" class="mt-4">Find an order</Button>
      </Card>
    ) : order ? (
      <>
        <header class="mb-6">
          <p class="text-caption text-neutral-500 uppercase tracking-wide m-0">Order receipt</p>
          <h1 class="text-display text-brand-600 m-0 mt-1">{formatPhp(order.grossAmount)}</h1>
          <Badge variant={statusVariant} class="mt-2">{orderStatusLabel(order.status)}</Badge>
          <p class="text-body text-neutral-500 mt-3 m-0">
            {
              order.status === "PENDING_PICKUP"
                ? "Bring this order reference to the counter and pay when you pick up."
                : order.status === "POSTED_TO_LEDGER"
                  ? "Payment recorded. Thank you for shopping with your coop."
                  : order.status === "FAILED"
                    ? "Payment was received but ledger posting failed — staff can retry below."
                    : "Order status updates will appear here."
            }
          </p>
        </header>

        <Card class="mb-6">
          <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 m-0 text-body-sm">
            <dt class="text-neutral-500">Order ID</dt>
            <dd class="m-0 font-mono text-body-sm break-all">{order.orderId}</dd>
            <dt class="text-neutral-500">Email</dt>
            <dd class="m-0">{order.guestEmail}</dd>
            <dt class="text-neutral-500">Vendor</dt>
            <dd class="m-0">{order.vendorCode}</dd>
          </dl>
        </Card>

        <Card class="mb-6">
          <h2 class="text-title-sm m-0 mb-3">Items</h2>
          <ul class="list-none m-0 p-0 divide-y divide-neutral-200">
            {
              order.lines.map((line) => (
                <li class="flex justify-between gap-4 py-3 text-body-sm">
                  <span>
                    {line.quantity}× {line.productName}
                  </span>
                  <span class="font-medium">{formatPhp(line.lineGross)}</span>
                </li>
              ))
            }
          </ul>
        </Card>

        {
          (order.status === "PENDING_PICKUP" || order.status === "FAILED") && (
            <div id="staff-confirm" data-order-id={order.orderId} data-api-base={API_BASE}>
            <Card class="border-accent-600 bg-accent-50">
              <h2 class="text-title-sm m-0 mb-2">
                {order.status === "FAILED" ? "Staff — retry ledger" : "Staff — confirm pickup"}
              </h2>
              {order.accountingError && (
                <p class="text-body-sm text-danger-600 m-0 mb-3">Last error: {order.accountingError}</p>
              )}
              <label class="block text-body-sm font-medium mb-3">
                Staff secret
                <input
                  type="password"
                  id="admin-secret"
                  class="mt-1.5 w-full min-h-touch px-4 rounded-lg border border-neutral-200"
                  autocomplete="off"
                />
              </label>
              <Button type="button" variant="staff" id="confirm-pickup">
                {order.status === "FAILED" ? "Retry post to ledger" : "Mark paid & post ledger"}
              </Button>
              <p id="admin-msg" class="hidden text-body-sm mt-3 m-0" role="status" />
            </Card>
            </div>
          )
        }

        <div class="mt-6">
          <Button href="/category/products" variant="secondary">
            Continue shopping
          </Button>
        </div>
      </>
    ) : null
  }
</MarketplaceLayout>

{
  showStaffConfirm && (
    <script>
      import { setupOrderConfirm } from "@/scripts/order-confirm";
      const card = document.getElementById("staff-confirm");
      if (card?.dataset.apiBase && card.dataset.orderId) {
        setupOrderConfirm(card.dataset.apiBase, card.dataset.orderId);
      }
    </script>
  )
}

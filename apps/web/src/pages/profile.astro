---
import MarketplaceLayout from "@/layouts/MarketplaceLayout.astro";
import RouteStub from "@/features/shared/RouteStub.astro";
import PersonaSwitcher from "@/components/organisms/shell/PersonaSwitcher.astro";
import Card from "@/components/atoms/Card.astro";
import Select from "@/components/atoms/Select.astro";
import { PERSONAS } from "@/stores/persona";
---

<MarketplaceLayout title="You">
  <div class="max-w-lg mx-auto space-y-6">
    <RouteStub
      title="Your account"
      description="Profile, sign-in, and settings ship in Sprint 4. Persona switching is available below for layout testing."
    />
    <Card>
      <h2 class="text-title-sm m-0 mb-4">Persona (framework)</h2>
      <p class="text-body-sm text-neutral-500 m-0 mb-4">
        Switch how you view the store. No role-specific features are enabled in Sprint 1.
      </p>
      <div class="flex justify-center mb-4">
        <PersonaSwitcher />
      </div>
      <Select
        id="persona-demo"
        name="persona-demo"
        label="Persona reference"
        hint="Read-only list of supported personas"
        options={PERSONAS.map((p) => ({ value: p.id, label: p.label }))}
        disabled
      />
    </Card>
  </div>
</MarketplaceLayout>

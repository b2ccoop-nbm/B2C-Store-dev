---
import MarketplaceLayout from "@/layouts/MarketplaceLayout.astro";
import Button from "@/components/atoms/Button.astro";
import Card from "@/components/atoms/Card.astro";
import PersonaSwitcher from "@/components/organisms/shell/PersonaSwitcher.astro";
---

<MarketplaceLayout title="You" mobileHeaderTitle="You">
  <header class="mb-6">
    <h1 class="text-display m-0">You</h1>
    <p class="text-body-sm text-neutral-500 mt-2 m-0">Your coop store account and activity.</p>
  </header>

  <div class="max-w-lg space-y-4">
    <Card>
      <h2 class="text-title-sm m-0 mb-3">Quick links</h2>
      <div class="flex flex-col gap-2">
        <Button href="/activity" variant="secondary" fullWidth>My activity</Button>
        <Button href="/cart" variant="secondary" fullWidth>Cart</Button>
        <Button href="/my-coop" variant="secondary" fullWidth>My Coop</Button>
      </div>
    </Card>

    <Card>
      <h2 class="text-title-sm m-0 mb-2">Sign in</h2>
      <p class="text-body-sm text-neutral-500 m-0 mb-4">
        Member sign-in and settings are coming soon. You can shop and checkout as a guest today.
      </p>
      <div class="flex justify-center">
        <PersonaSwitcher />
      </div>
    </Card>
  </div>
</MarketplaceLayout>

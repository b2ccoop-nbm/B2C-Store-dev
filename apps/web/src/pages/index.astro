---
import MarketplaceLayout from "@/layouts/MarketplaceLayout.astro";
import Button from "@/components/atoms/Button.astro";
import Badge from "@/components/atoms/Badge.astro";
import CatalogGrid from "@/components/molecules/CatalogGrid.astro";
import Card from "@/components/atoms/Card.astro";
import { fetchCatalog, groupByCategory } from "@/services/catalog";

let items: Awaited<ReturnType<typeof fetchCatalog>>["items"] = [];
let error = "";

try {
  const catalog = await fetchCatalog();
  items = catalog.items;
} catch (e) {
  error = e instanceof Error ? e.message : "Could not load products";
}

const categories = Object.keys(groupByCategory(items)).sort();
const featured = items.slice(0, 6);
---

<MarketplaceLayout title="Home" description="B2CCoop cooperative store — shop local products">
  <section class="mb-8">
    <Badge variant="coop">B2C Consumers Cooperative</Badge>
    <h1 class="text-display mt-3 mb-2 text-neutral-900">Shop the coop store</h1>
    <p class="text-body text-neutral-500 max-w-prose m-0">
      Browse products, add to cart, and pay when you pick up at the counter.
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      <Button href="/category/products" variant="primary">All products</Button>
      <Button href="/search" variant="secondary">Search</Button>
    </div>
  </section>

  {error ? (
    <Card class="border-danger-600 bg-danger-50">
      <p class="text-body text-danger-600 m-0">{error}</p>
      <p class="text-body-sm text-neutral-500 mt-2 m-0">Start the API with <code>npm run dev:api</code></p>
    </Card>
  ) : (
    <>
      {categories.length > 0 && (
        <section class="mb-8">
          <h2 class="text-title-sm mb-3">Categories</h2>
          <div class="flex flex-wrap gap-2">
            {
              categories.map((cat) => (
                <Button
                  href={`/category/${cat.toLowerCase().replace(/\s+/g, "-")}`}
                  variant="secondary"
                  size="sm"
                >
                  {cat}
                </Button>
              ))
            }
          </div>
        </section>
      )}

      <section>
        <h2 class="text-title-sm mb-4">Featured products</h2>
        <CatalogGrid items={featured} />
        {items.length > featured.length && (
          <div class="mt-6 text-center">
            <Button href="/category/products" variant="ghost">
              View all {items.length} products →
            </Button>
          </div>
        )}
      </section>
    </>
  )}
</MarketplaceLayout>

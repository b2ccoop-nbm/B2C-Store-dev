---
import Layout from "../layouts/Layout.astro";

const apiBase = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8787";
---

<Layout title="Staff — B2CCoop Store">
  <section class="hero">
    <h1>Pickup queue</h1>
    <p class="lead">Orders awaiting payment at the counter.</p>
  </section>

  <label>
    DEV_ADMIN_SECRET
    <input type="password" id="admin-secret" />
  </label>
  <button type="button" id="load-pending" class="primary">Load pending orders</button>

  <div id="list" class="list"></div>
  <p id="msg" class="hidden"></p>
</Layout>

<style>
  h1 { margin: 0 0 0.25rem; }
  .lead { color: #64748b; margin: 0 0 1.5rem; }
  label { display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 1rem; }
  input {
    display: block;
    width: 100%;
    max-width: 24rem;
    margin-top: 0.35rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid #cbd5e1;
    border-radius: 0.5rem;
    font: inherit;
  }
  .primary {
    background: #b45309;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    padding: 0.65rem 1rem;
    font-weight: 600;
    cursor: pointer;
    margin-bottom: 1.5rem;
  }
  .order-card {
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 0.75rem;
  }
  .hidden { display: none; }
  .bad { color: #b91c1c; }
</style>

<script define:vars={{ apiBase }}>
  const loadBtn = document.getElementById("load-pending");
  const secretInput = document.getElementById("admin-secret");
  const list = document.getElementById("list");
  const msg = document.getElementById("msg");

  loadBtn?.addEventListener("click", async () => {
    const secret = secretInput?.value?.trim();
    if (!secret) {
      msg.textContent = "Enter DEV_ADMIN_SECRET";
      msg.className = "bad";
      msg.classList.remove("hidden");
      return;
    }
    try {
      const res = await fetch(`${apiBase}/admin/orders/pending`, {
        headers: { Authorization: `Bearer ${secret}` },
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? "Load failed");
      if (!data.orders?.length) {
        list.innerHTML = "<p>No pending pickup orders.</p>";
        return;
      }
      list.innerHTML = data.orders
        .map(
          (o) => `
        <article class="order-card">
          <strong>₱${Number(o.grossAmount).toFixed(2)}</strong> — ${o.guestEmail}<br />
          <small>${o.externalId}</small><br />
          <a href="/order/${o.orderId}">Open receipt →</a>
        </article>`,
        )
        .join("");
      msg.classList.add("hidden");
    } catch (err) {
      msg.textContent = err instanceof Error ? err.message : "Load failed";
      msg.className = "bad";
      msg.classList.remove("hidden");
    }
  });
</script>

---
import MarketplaceLayout from "@/layouts/MarketplaceLayout.astro";
import Card from "@/components/atoms/Card.astro";
import Button from "@/components/atoms/Button.astro";
import Input from "@/components/atoms/Input.astro";
---

<MarketplaceLayout title="My activity" mobileHeaderTitle="Activity">
  <header class="mb-6">
    <h1 class="text-display m-0">My activity</h1>
    <p class="text-body-sm text-neutral-500 mt-2 m-0">
      Your orders and receipts from the coop store.
    </p>
  </header>

  <Card class="max-w-md mb-8">
    <form id="activity-email-form" class="space-y-4">
      <Input
        id="activity-email"
        name="email"
        type="email"
        label="Your email"
        placeholder="Same email used at checkout"
        required
        autocomplete="email"
      />
      <Button type="submit" variant="primary" fullWidth>Load my orders</Button>
    </form>
    <p id="activity-error" class="hidden text-body-sm text-danger-600 mt-3 m-0" role="alert" />
  </Card>

  <div class="flex gap-2 mb-6 border-b border-neutral-200" role="tablist" aria-label="Activity filters">
    <button
      type="button"
      data-activity-tab="active"
      class="px-4 py-3 text-body-sm font-semibold border-b-2 border-brand-600 text-brand-600 bg-transparent cursor-pointer"
      role="tab"
      aria-selected="true"
    >
      Active
    </button>
    <button
      type="button"
      data-activity-tab="completed"
      class="px-4 py-3 text-body-sm font-medium text-neutral-500 bg-transparent border-b-2 border-transparent cursor-pointer"
      role="tab"
      aria-selected="false"
    >
      Completed
    </button>
  </div>

  <p id="activity-empty" class="text-body-sm text-neutral-500 m-0 mb-4">
    Enter your email above to see orders.
  </p>
  <div id="activity-order-list" class="space-y-3 max-w-2xl" />

  <section class="mt-12" aria-labelledby="find-order-heading">
    <h2 id="find-order-heading" class="text-title-sm m-0 mb-2">Find a single order</h2>
    <p class="text-body-sm text-neutral-500 m-0 mb-4">
      Have an order ID from your receipt? Look it up directly.
    </p>
    <Card class="max-w-md">
      <form id="find-order-form" class="space-y-4">
        <Input id="order-id" name="orderId" label="Order ID" placeholder="From your receipt" required autocomplete="off" />
        <Input id="order-email" name="email" type="email" label="Email used at checkout" required />
        <Button type="submit" variant="secondary" fullWidth id="find-submit">View order</Button>
      </form>
      <p id="find-error" class="hidden text-body-sm text-danger-600 mt-3 m-0" role="alert" />
    </Card>
  </section>
</MarketplaceLayout>

<script>
  import { setupActivityOrders } from "@/scripts/activity-orders";
  import { setupFindOrder } from "@/scripts/find-order";
  import { API_BASE } from "@/lib/api";
  setupActivityOrders(API_BASE);
  setupFindOrder(API_BASE);
</script>

---
import Layout from "../layouts/Layout.astro";

const apiBase = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8787";
let catalog: {
  itemCount?: number;
  items?: Array<{
    vendorCode: string;
    sku: string;
    name: string;
    category: string;
    unitPrice: string;
    patronagePerUnit: string;
    currency: string;
  }>;
  devAccounts?: {
    guestCheckout: string;
    members: string[];
    staff: string[];
  };
} | null = null;
let error = "";

try {
  const res = await fetch(`${apiBase}/catalog`);
  catalog = await res.json();
} catch {
  error = `Could not load catalog from ${apiBase}/catalog — is npm run dev:api running?`;
}

function formatPhp(value: string) {
  return `₱${Number(value).toLocaleString("en-PH", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}

type CatalogItem = {
  vendorCode: string;
  sku: string;
  name: string;
  category: string;
  unitPrice: string;
  patronagePerUnit: string;
  currency: string;
};

const byCategory = (catalog?.items ?? []).reduce<Record<string, CatalogItem[]>>((acc, item) => {
  const key = item.category || "General";
  acc[key] ??= [];
  acc[key]!.push(item);
  return acc;
}, {});
---

<Layout title="Catalog — B2CCoop Store">
  <section class="hero">
    <h1>Coop catalog</h1>
    <p class="lead">{catalog?.itemCount ?? 0} products · dev mock data</p>
  </section>

  {error ? (
    <p class="error">{error}</p>
  ) : (
    <>
      {catalog?.devAccounts && (
        <section class="panel dev-accounts">
          <h2>Dev test accounts</h2>
          <p><strong>Guest checkout:</strong> <code>{catalog.devAccounts.guestCheckout}</code></p>
          <p><strong>Members:</strong>{" "}
            {catalog.devAccounts.members.map((e) => (
              <code>{e}</code>
            ))}
          </p>
          <p><strong>Staff:</strong>{" "}
            {catalog.devAccounts.staff.map((e) => (
              <code>{e}</code>
            ))}
          </p>
          <p class="hint">See <a href="https://github.com/b2ccoop-nbm/B2C-Store-dev/blob/main/docs/DEV-TESTING.md">docs/DEV-TESTING.md</a> in the repo.</p>
        </section>
      )}

      {Object.entries(byCategory).sort(([a], [b]) => a.localeCompare(b)).map(([category, items]) => (
        <section class="category">
          <h2>{category}</h2>
          <ul class="grid">
            {items!.map((item) => (
              <li class="card">
                <p class="sku">{item.sku}</p>
                <h3>{item.name}</h3>
                <p class="price">{formatPhp(item.unitPrice)}</p>
                <p class="meta">Patronage {formatPhp(item.patronagePerUnit)} · {item.vendorCode}</p>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </>
  )}
</Layout>

<style>
  .hero { margin-bottom: 1.5rem; }
  h1 { margin: 0 0 0.25rem; font-size: 1.75rem; }
  .lead { color: #64748b; margin: 0; }
  .panel {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .panel h2 { margin: 0 0 0.75rem; font-size: 1rem; }
  .panel p { margin: 0.35rem 0; font-size: 0.9rem; }
  code {
    background: #ecfdf5;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
    margin-right: 0.35rem;
  }
  .hint { margin-top: 0.75rem; font-size: 0.8rem; color: #64748b; }
  .category { margin-bottom: 2rem; }
  .category h2 {
    font-size: 1.1rem;
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 0.35rem;
    margin-bottom: 1rem;
  }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
  }
  .card {
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 1rem;
    background: #fff;
  }
  .sku { font-size: 0.7rem; color: #94a3b8; margin: 0 0 0.25rem; text-transform: uppercase; }
  .card h3 { margin: 0 0 0.5rem; font-size: 0.95rem; line-height: 1.3; }
  .price { margin: 0; font-weight: 700; color: #0e7490; }
  .meta { margin: 0.35rem 0 0; font-size: 0.75rem; color: #64748b; }
  .error { color: #b91c1c; }
</style>

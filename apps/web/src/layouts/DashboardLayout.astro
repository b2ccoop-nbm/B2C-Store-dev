---
import BaseLayout from "./BaseLayout.astro";
import DesktopHeader from "@/components/organisms/shell/DesktopHeader.astro";
import MobileHeader from "@/components/organisms/shell/MobileHeader.astro";
import TrustFooter from "@/components/organisms/shell/TrustFooter.astro";
import OfficerBanner from "@/components/organisms/shell/OfficerBanner.astro";
import { cn } from "@/lib/cn";

interface Props {
  title: string;
  description?: string;
  section: "sell";
}

const { title, description } = Astro.props;
const activePath = Astro.url.pathname;

const sellLinks = [
  { label: "Dashboard", href: "/sell" },
  { label: "Apply to sell", href: "/sell/apply" },
  { label: "Listings", href: "/sell/listings" },
  { label: "New listing", href: "/sell/new" },
  { label: "Order queue", href: "/sell/activity" },
];
---

<BaseLayout title={title} description={description}>
  <OfficerBanner slot="banner" />
  <MobileHeader title={title} />
  <DesktopHeader activePath={activePath} />
  <div class="mx-auto max-w-7xl px-4 md:px-6 py-6">
    <div class="lg:grid lg:grid-cols-[14rem_1fr] lg:gap-8">
      <aside class="hidden lg:block" aria-label="Merchant navigation">
        <nav class="sticky top-24 flex flex-col gap-1">
          <p class="text-caption font-semibold uppercase tracking-wide text-merchant-600 px-3 mb-2">
            Merchant
          </p>
          {
            sellLinks.map((link) => (
              <a
                href={link.href}
                class={cn(
                  "touch-target flex items-center rounded-lg px-3 text-body-sm font-medium no-underline",
                  activePath === link.href
                    ? "bg-merchant-50 text-merchant-600"
                    : "text-neutral-900 hover:bg-neutral-50",
                )}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </aside>
      <main id="main-content" class="min-h-[50vh]">
        <slot />
      </main>
    </div>
  </div>
  <TrustFooter />
</BaseLayout>

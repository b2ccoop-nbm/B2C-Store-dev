---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="B2CCoop cooperative store — member-owned marketplace." />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href="/" class="brand">B2CCoop Store</a>
      <nav>
        <a href="/catalog">Catalog</a>
        <a href="/cart">Cart</a>
        <a href="/admin">Staff</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>B2C Consumers Cooperative · Phase 1 MVP</small>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family:
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      sans-serif;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    min-height: 100vh;
    background: #fff;
    color: #0f172a;
  }
  header {
    border-bottom: 1px solid #e2e8f0;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  nav {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
  }
  nav a {
    color: #475569;
    text-decoration: none;
  }
  nav a:hover {
    color: #0e7490;
  }
  .brand {
    font-weight: 700;
    color: #0e7490;
    text-decoration: none;
  }
  main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
  }
  footer {
    border-top: 1px solid #e2e8f0;
    padding: 1rem 1.5rem;
    color: #64748b;
    text-align: center;
  }
</style>
